{
  "name": "@playerkit/ui",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imnurav/playerkit.git"
  },
  "homepage": "https://github.com/imnurav/playerkit#readme",
  "bugs": {
    "url": "https://github.com/imnurav/playerkit/issues"
  },
  "description": "React UI components and themes for HLS video players — progress bar, volume control, settings panel, icon system, and customizable theming.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": {
      "types": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./styles/common.css": {
      "types": "./dist/styles/common.d.ts",
      "default": "./dist/styles/common.css"
    },
    "./styles/hls.css": {
      "types": "./dist/styles/hls.d.ts",
      "default": "./dist/styles/hls.css"
    },
    "./styles/mp4.css": {
      "types": "./dist/styles/mp4.d.ts",
      "default": "./dist/styles/mp4.css"
    },
    "./styles/youtube.css": {
      "types": "./dist/styles/youtube.d.ts",
      "default": "./dist/styles/youtube.css"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "hls",
    "mp4",
    "video",
    "player",
    "react",
    "ui",
    "player-controls",
    "video-ui",
    "progress-bar",
    "volume",
    "settings",
    "theme",
    "components",
    "typescript"
  ],
  "author": "Nurav",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@playerkit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}